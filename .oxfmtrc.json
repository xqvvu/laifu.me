{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortTailwindcss": true,
  "sortImports": true,
  "sortPackageJson": true,
  "ignorePatterns": ["**/*.md", ".nuxt", ".output", "dist", "node_modules", "pnpm-lock.yaml"]
}
