  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "check": "pnpm lint && pnpm build",
    "typecheck": "nuxt typecheck",
    "dev": "nuxt dev -p 5173",
    "format": "oxfmt . \"!**/*.md\"",
    "format:check": "oxfmt --check . \"!**/*.md\"",
