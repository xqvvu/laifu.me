    "@iconify/tailwind4": "^1.2.3",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "eslint": "^9.39.4",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-tailwindcss": "^3.18.3",
